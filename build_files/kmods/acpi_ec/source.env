# acpi_ec out-of-tree module — pinned source for the generic kmod builder.
# Consumed by build_files/kmods/build-kmods.sh (sourced, not executed).
#
# ec_sys reworked as a char device: creates root-only (0600) /dev/ec, the
# fallback interface MControlCenter uses (readwrite.cpp: acpi_ec_file="/dev/ec")
# for fan RPM and fan curves when the in-kernel ec_sys debugfs is absent — the
# ogc kernel builds with CONFIG_ACPI_EC_DEBUGFS off, so ec_sys cannot load.
URL=https://github.com/saidsay-so/acpi_ec.git
# Pinned commit for tag v1.0.4 (the tag is annotated; pin the commit).
COMMIT=75102ceffdd4df4fb23b05bf92cf00f1da3d93c3
# Built object base name (the source builds acpi_ec.ko).
KO_NAME=acpi_ec
# The root Makefile sets `obj-m += src/acpi_ec.o` with M=$(PWD), so the object
# is emitted under src/ rather than the clone root (unlike msi-ec).
KO_BUILD_PATH=src/acpi_ec.ko
# Destination subpath under /usr/lib/modules/<kver>/. No in-tree copy exists
# (CONFIG_ACPI_EC_DEBUGFS off) so updates/ overrides nothing — placement is
# purely for a clean, depmod-discoverable location.
KO_DEST=updates/drivers/acpi
