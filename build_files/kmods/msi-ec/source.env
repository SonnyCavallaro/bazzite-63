# msi-ec out-of-tree module — pinned source for the generic kmod builder.
# Consumed by build_files/kmods/build-kmods.sh (sourced, not executed).
URL=https://github.com/BeardOverflow/msi-ec.git
# Pinned commit on main carrying the 17L5EMS1.115 (Katana 17 B13V/GK) entry.
COMMIT=e538f850f9dec6294fd74c90ba64f3d77f7d657d
# Built object base name (the source builds msi-ec.ko).
KO_NAME=msi-ec
# Destination subpath under /usr/lib/modules/<kver>/ — updates/ outranks kernel/.
KO_DEST=updates/drivers/platform/x86
