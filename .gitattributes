# Force LF line endings for all build/runtime files: CRLF breaks shell
# interpreters and config parsing inside the Linux container.
* text=auto eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.just text eol=lf
*.repo text eol=lf
*.conf text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.service text eol=lf
Containerfile text eol=lf
*.md text eol=lf

# Binary assets: never normalize.
*.png binary
*.jpg binary
*.ico binary
*.pub binary
