#!/usr/bin/bash
# Install the Flatpaks declared in /usr/share/ublue-os/bazzite/flatpak/install.
#
# Bazzite's own bazzite-flatpak-manager only maintains remotes, blocklist
# filters and overrides — the install list is consumed by the ISO installer
# alone. Apps ADDED to the list by this image (68-flatpak-apps.sh) would
# therefore never reach a system that installed the stock Bazzite ISO and
# then `bootc switch`ed here. This oneshot closes that gap.
#
# Stamped per script version (content hash), mirroring Bazzite's manager:
# it re-runs after an image update only when this script changes, and it
# retries via systemd Restart=on-failure when the network is not up yet
# (the stamp is only written after a fully successful install).

set -eou pipefail

VER=1
SCRIPT_HASH=$(tr -d '[:space:]' <"$0" | sha256sum | cut -d ' ' -f 1)
VER="$VER-$SCRIPT_HASH"
VER_FILE="/etc/bazzite/b63_flatpak_manager_version"
VER_RAN=$(cat "$VER_FILE" 2>/dev/null || true)

if [[ -f $VER_FILE && $VER = $VER_RAN ]]; then
    echo "bazzite-63 flatpak manager v$VER has already run. Exiting..."
    exit 0
fi

INSTALL_LIST=/usr/share/ublue-os/bazzite/flatpak/install
if [[ ! -f $INSTALL_LIST ]]; then
    echo "FAIL: $INSTALL_LIST missing (Bazzite layout changed?)"
    exit 1
fi

mapfile -t APPS < <(grep -vE '^\s*(#|$)' "$INSTALL_LIST")
flatpak install --system --assumeyes --or-update flathub "${APPS[@]}"

mkdir -p /etc/bazzite
echo "$VER" > "$VER_FILE"
echo "bazzite-63 flatpak manager v$VER completed."
